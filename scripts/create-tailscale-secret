#!/usr/bin/env bash
set -euo pipefail

print_help() {
  cat <<EOF
Usage: $0 [--client-id ID] [--client-secret SECRET] [--namespace NAMESPACE]

Create the operator-oauth Secret in the cluster for the Tailscale operator.

Options:
  --client-id       Tailscale OAuth client_id (or set TS_CLIENT_ID env)
  --client-secret   Tailscale OAuth client_secret (or set TS_CLIENT_SECRET env)
  --namespace       Kubernetes namespace (default: tailscale)
  -h, --help        Show this help and exit
EOF
}

NAMESPACE="tailscale"
CLIENT_ID="${TS_CLIENT_ID:-}"
CLIENT_SECRET="${TS_CLIENT_SECRET:-}"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --client-id)
      CLIENT_ID="$2"; shift 2;;
    --client-secret)
      CLIENT_SECRET="$2"; shift 2;;
    --namespace)
      NAMESPACE="$2"; shift 2;;
    -h|--help)
      print_help; exit 0;;
    *)
      echo "Unknown argument: $1" >&2; print_help; exit 2;;
  esac
done

if ! command -v kubectl >/dev/null 2>&1; then
  echo "kubectl not found in PATH" >&2
  exit 3
fi

if [[ -z "$CLIENT_ID" ]]; then
  read -rp "Tailscale client_id: " CLIENT_ID
fi
if [[ -z "$CLIENT_SECRET" ]]; then
  read -rsp "Tailscale client_secret: " CLIENT_SECRET
  echo
fi

if [[ -z "$CLIENT_ID" || -z "$CLIENT_SECRET" ]]; then
  echo "client_id and client_secret are required" >&2
  exit 4
fi

echo "Ensuring namespace '$NAMESPACE' exists..."
kubectl create namespace "$NAMESPACE" --dry-run=client -o yaml | kubectl apply -f -

echo "Applying operator-oauth Secret to namespace '$NAMESPACE'..."
kubectl create secret generic operator-oauth \
  --namespace "$NAMESPACE" \
  --from-literal=client_id="$CLIENT_ID" \
  --from-literal=client_secret="$CLIENT_SECRET" \
  --dry-run=client -o yaml | kubectl apply -f -

echo "operator-oauth secret applied to namespace '$NAMESPACE'."

exit 0
